{
  "appId": "kr.go.nps.seoraksan",
  "appName": "설악산 현장관리",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["seorak1275.github.io", "*.kakao.com", "*.kakaocdn.net", "dapi.kakao.com", "kauth.kakao.com", "kapi.kakao.com", "accounts.kakao.com"]
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#060d1a",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "CapacitorUpdater": {
      "autoUpdate": false,
      "appReadyTimeout": 10000,
      "responseTimeout": 20
    }
  }
}
