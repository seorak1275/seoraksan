rules_version = '2';
// ══════════════════════════════════════════════════════════════
// 설악산 현장관리 Firestore 보안 규칙
//
// 적용 방법:
//  1. Firebase 콘솔 → Authentication → Sign-in method → "익명" 활성화
//  2. Firebase 콘솔 → Firestore Database → 규칙 탭 → 이 파일 내용 붙여넣기 → 게시
//
// ※ sos 컬렉션은 조난·사고자(로그인 불가)가 위치를 보내야 하므로
//   인증 없이도 생성/수정 가능하게 별도 허용한다. (좌표 필드 필수)
//   읽기·삭제는 구조대(인증 사용자)만 가능.
// ══════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    // 🆘 조난·사고자 위치 전송: 공개 쓰기 허용(로그인 불필요), 목록·삭제는 구조대만
    //   단일 문서 get은 공개 허용 — 조난자가 자신의 토큰 링크 상태(종료·구조대 메시지)를 읽어야 함.
    //   (토큰을 모르면 문서 ID를 알 수 없어 노출 위험 없음 / list는 막아 전체 열람 차단)
    match /sos/{doc} {
      allow get: if true;
      allow list, delete: if request.auth != null;
      allow create, update: if request.resource.data.lat is number
                            && request.resource.data.lng is number
                            && request.resource.data.lat > 33 && request.resource.data.lat < 39
                            && request.resource.data.lng > 124 && request.resource.data.lng < 132;
    }

    // 그 외 모든 컬렉션: 인증된 요청만 (익명 인증 포함)
    match /{collection}/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
